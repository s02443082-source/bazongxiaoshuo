# Frontend optional overrides
# 大多数本地开发场景不需要这个文件。
# 如果不显式配置，开发环境默认会把 API 指到：
# http(s)://当前页面 hostname:3001/api
# 如果你通过局域网地址访问页面，不要把 API 固定成 localhost，
# 否则浏览器会去请求“当前访问设备自己的 localhost:3001”。

# 当前机器的 3000 端口常被其它服务占用，这里默认显式指向小说工作台后端。
VITE_API_BASE_URL=http://127.0.0.1:3001/api
# 默认 10 分钟，可按需要调大。
VITE_API_TIMEOUT_MS=600000
